<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/notification_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:baselineAligned="false"
    android:background="@android:color/transparent"
    android:paddingStart="0dp"
    android:paddingEnd="12dp"
    android:paddingTop="0dp"
    android:paddingBottom="8dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/notification_profile_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:textSize="14sp"
            android:maxLines="2"
            android:ellipsize="none"
            android:includeFontPadding="false"
            android:textColor="@android:color/white" />

        <TextView
            android:id="@+id/notification_quote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textSize="12sp"
            android:maxLines="4"
            android:ellipsize="none"
            android:includeFontPadding="false"
            android:alpha="0.78"
            android:textColor="@android:color/white" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:orientation="vertical"
        android:gravity="end|center_vertical">

        <LinearLayout
            android:id="@+id/notification_status_row"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:visibility="gone"
            tools:ignore="UseCompoundDrawables">

            <ImageView
                android:id="@+id/notification_status_icon"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_notification_target"
                android:contentDescription="@null" />

            <TextView
                android:id="@+id/notification_status_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@android:color/white" />
        </LinearLayout>

        <TextView
            android:id="@+id/notification_timer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:textSize="22sp"
            android:includeFontPadding="false"
            android:textColor="@android:color/white" />
    </LinearLayout>
</LinearLayout>
